Use cWebView.pkg
Use cWebForm.pkg
Use DDSrc/Liga.dd

Object oLigaZoom is a cWebView
    Set psCaption to "Detalle de Liga"
    Object oLiga_DD is a Liga_DD
    End_Object
    Set Main_DD to oLiga_DD
    Object oNombre is a cWebForm
        Entry_Item Liga.Nombre
        Set psCaption to "Nombre"
    End_Object
    Object oPais is a cWebForm
        Entry_Item Liga.Pais
        Set psCaption to "País"
    End_Object
End_Object
