Use cWebView.pkg
Use cWebForm.pkg
Use DDSrc/Posicion.dd

Object oPosicionZoom is a cWebView
    Set psCaption to "Detalle de Posición"
    Object oPosicion_DD is a Posicion_DD
    End_Object
    Set Main_DD to oPosicion_DD
    Object oNombre is a cWebForm
        Entry_Item Posicion.Nombre
        Set psCaption to "Nombre"
    End_Object
End_Object
