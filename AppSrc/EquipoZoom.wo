Use cWebView.pkg
Use cWebForm.pkg
Use DDSrc/Equipo.dd

Object oEquipoZoom is a cWebView
    Set psCaption to "Detalle de Equipo"
    Object oEquipo_DD is a Equipo_DD
    End_Object
    Set Main_DD to oEquipo_DD
    Object oNombre is a cWebForm
        Entry_Item Equipo.Nombre
        Set psCaption to "Nombre"
    End_Object
End_Object
