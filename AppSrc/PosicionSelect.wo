Use cWebView.pkg
Use cWebList.pkg
Use DDSrc/Posicion.dd

Object oPosicionSelect is a cWebView
    Set psCaption to "Seleccionar Posición"
    Object oPosicion_DD is a Posicion_DD
    End_Object
    Set Main_DD to oPosicion_DD
    Object oList is a cWebList
        Object oNombre is a cWebColumn
            Entry_Item Posicion.Nombre
            Set psCaption to "Nombre"
        End_Object
    End_Object
End_Object
